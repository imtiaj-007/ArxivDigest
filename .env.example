# ArxivDigest environment variables.
#
# Copy this file to .env (gitignored) and fill in real values.
# Real values also live in your password manager + CI secrets (GitHub Actions, Vercel).
#
# Loading:
#   - apps/agent reads .env via python-dotenv (pydantic-settings)
#   - apps/web reads .env.local natively (Next.js)
#   - packages/db reads .env via drizzle-kit's dotenv loader


# === Database (Supabase Postgres + pgvector) ===
# Format: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# Use the *transaction-mode pooler* URL (port 6543), not the direct 5432.
DATABASE_URL=


# === LLM providers ===
# Primary: Groq (Llama 3.3 70B). Failover: Google Gemini 2.0 Flash.
GROQ_API_KEY=
GEMINI_API_KEY=


# === Embeddings ===
# Local BAAI/bge-large-en-v1.5 via sentence-transformers — no API key needed.
# VOYAGE_API_KEY kept here only for the dormant adapter; safe to leave unset.
VOYAGE_API_KEY=


# === Web revalidation hook (apps/web) ===
# Token-gated POST to /api/revalidate that the daily cron fires after publish
# to bust ISR caches on the data-driven pages. Generate with:
#   openssl rand -hex 32
# Set the same value as REVALIDATE_TOKEN on the web (Vercel env) and as
# WEB_REVALIDATE_TOKEN in the GH `production` env. WEB_REVALIDATE_URL is the
# Vercel deployment URL + /api/revalidate.
REVALIDATE_TOKEN=
WEB_REVALIDATE_URL=https://arxiv-digest-preview.vercel.app/api/revalidate
WEB_REVALIDATE_TOKEN=


# === Observability ===
# Langfuse (LLM trace observability — agent only).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Sentry (error tracking — agent + web).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Browser-side Sentry (must be NEXT_PUBLIC_* to ship to the client bundle).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Build-time only — set in CI to enable source-map upload + release tracking.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=


# === Runtime ===
# Used by structlog + Sentry to pick dev/prod behaviour.
APP_ENV=development
LOG_LEVEL=INFO
